---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Guillaume Braillon" } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Accueil" },
  { href: "/projects", label: "Projets" },
  { href: "/voyages", label: "Voyages" },
  { href: "/articles", label: "Articles" },
  { href: "/cv", label: "CV" },
];
---

<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body
    class="bg-[#ffffff] text-[#1f2328] antialiased min-h-screen flex flex-col text-sm font-[-apple-system,BlinkMacSystemFont,'Segoe_UI',Noto_Sans,Helvetica,Arial,sans-serif,'Apple_Color_Emoji','Segoe_UI_Emoji']"
  >
    <header class="w-full bg-[#f6f8fa] border-b border-[#d0d7de]">
      <div class="max-w-5xl mx-auto px-4 h-12 flex items-center justify-between">
        <a
          href="/"
          class="flex items-center gap-1.5 font-semibold text-[#1f2328] hover:text-[#0969da] transition-colors text-xs tracking-tight"
        >
          <svg height="16" viewBox="0 0 16 16" width="16" class="fill-[#1f2328]">
            <path
              d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82A7.49 7.49 0 0 0 8 3c-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.16.73.72.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"
            ></path>
          </svg>
          <span>guillaume-braillon</span>
        </a>

        <nav class="flex items-center gap-0.5">
          {
            navItems.map((item) => {
              const isActive =
                currentPath === item.href ||
                (item.href !== "/" && currentPath.startsWith(item.href));
              return (
                <a
                  href={item.href}
                  class={`px-2 py-1 text-xs font-normal rounded-md transition-colors ${
                    isActive
                      ? "text-[#1f2328] font-semibold ring-1 ring-[#d0d7de] shadow-sm bg-white"
                      : "text-[#636c76] hover:text-[#1f2328] hover:bg-[#eaeef2]"
                  }`}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-6">
      <div
        class="bg-white border border-[#d0d7de] rounded-md p-5 shadow-sm text-[14px] leading-relaxed"
      >
        <slot />
      </div>
    </main>

    <footer class="mt-auto border-t border-[#d0d7de] bg-[#ffffff]">
      <div
        class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between text-[12px] text-[#636c76]"
      >
        <div class="flex items-center gap-2">
          <svg height="14" viewBox="0 0 16 16" width="14" class="fill-[#636c76] opacity-60">
            <path
              d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82A7.49 7.49 0 0 0 8 3c-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.16.73.72.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"
            ></path>
          </svg>
          <span>© {new Date().getFullYear()} Guillaume Braillon</span>
        </div>
        <nav class="flex gap-3">
          <a
            href="https://github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#0969da] hover:underline">GitHub</a
          >
          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#0969da] hover:underline">LinkedIn</a
          >
        </nav>
      </div>
    </footer>
  </body>
</html>
