---
import "../styles/global.css";
import { navItems, site, socialLinks } from "../data/site";

interface Props {
  title?: string;
}

const { title = site.defaultTitle } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body
    class="bg-[#ffffff] text-[#1f2328] antialiased min-h-screen flex flex-col text-sm font-[-apple-system,BlinkMacSystemFont,'Segoe_UI',Noto_Sans,Helvetica,Arial,sans-serif,'Apple_Color_Emoji','Segoe_UI_Emoji']"
  >
    <header class="w-full bg-[#f6f8fa] border-b border-[#d0d7de]">
      <div
        class="max-w-5xl mx-auto px-4 py-2.5 sm:py-0 sm:h-12 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2.5 sm:gap-4"
      >
        <!-- Tagline à gauche -->
        <a
          href="/"
          class="flex items-center font-semibold text-[#1f2328] hover:text-[#0969da] transition-colors text-xs tracking-tight py-0.5 sm:py-0"
        >
          <span>{site.tagline}</span>
        </a>

        <!-- Menu aligné à gauche, taille naturelle des boutons -->
        <nav
          class="flex flex-wrap items-center justify-start sm:justify-end gap-x-0.5 gap-y-1.5 w-full sm:w-auto"
        >
          {
            navItems.map((item) => {
              const isActive =
                currentPath === item.href ||
                (item.href !== "/" && currentPath.startsWith(item.href));
              return (
                <a
                  href={item.href}
                  class={`px-2 py-1.5 text-xs rounded-md transition-colors shrink-0 ${
                    isActive
                      ? "text-[#1f2328] font-semibold ring-1 ring-[#d0d7de] shadow-sm bg-white"
                      : "text-[#636c76] hover:text-[#1f2328] hover:bg-[#eaeef2]"
                  }`}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-6">
      <div
        class="bg-white border border-[#d0d7de] rounded-md p-5 shadow-sm text-[14px] leading-relaxed"
      >
        <slot />
      </div>
    </main>

    <footer class="mt-auto border-t border-[#d0d7de] bg-[#ffffff]">
      <div
        class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between text-[12px] text-[#636c76]"
      >
        <div class="flex items-center gap-2">
          <span>© {new Date().getFullYear()} {site.name}</span>
        </div>
        <nav class="flex gap-3">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#0969da] hover:underline"
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </footer>
  </body>
</html>
