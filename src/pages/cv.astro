---
import SkillGroup from "../components/SkillGroup.astro";
import Layout from "../layouts/Layout.astro";
import { profile, skills, experiences, educations } from "../data/cv";
---

<Layout title={`CV - ${profile.name}`}>
  <div class="space-y-6">
    <header
      class="pb-6 border-b border-[#d0d7de] flex flex-col md:flex-row md:items-start justify-between gap-4"
    >
      <div>
        <h1 class="text-2xl font-semibold text-[#1f2328] tracking-tight flex items-center gap-2">
          {profile.name}
          <span class="gh-badge gh-badge--home text-xs font-normal"> Disponible </span>
        </h1>
        <p class="text-base font-medium text-[#0969da] mt-1">{profile.title}</p>
        <p class="text-xs text-[#57606a] font-mono mt-0.5">{profile.subtitle}</p>
        <p class="mt-3 text-[14px] text-[#24292f] leading-relaxed max-w-3xl">
          {profile.details}
        </p>
      </div>

      <div
        class="shrink-0 p-3 gh-surface-muted gh-card space-y-1.5 text-xs gh-text-muted font-mono min-w-60"
      >
        <div class="flex items-center gap-2">
          <span class="font-semibold gh-text w-14">Web:</span>
          <a href={`https://${profile.website}`} target="_blank" class="gh-link hover:underline"
            >{profile.website}</a
          >
        </div>
        <div class="flex items-center gap-2">
          <span class="font-semibold gh-text w-14">GitHub:</span>
          <a href={`https://${profile.github}`} target="_blank" class="gh-link hover:underline"
            >GuillaumeBraillon</a
          >
        </div>
        <div class="pt-1.5 gh-divider-bottom text-[11px]">
          Permis B · {profile.lang}
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-6">
        <section>
          <h2 class="text-xs font-semibold text-[#1f2328] uppercase tracking-wider mb-3">
            Expériences Professionnelles
          </h2>
          <div class="space-y-4">
            {
              experiences.map((exp) => (
                <div class="gh-card p-4 hover:border-[#0969da] transition-colors group">
                  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-1">
                    <div>
                      <h3 class="text-[14px] font-semibold gh-text">{exp.role}</h3>
                      <p class="text-xs font-medium gh-link mt-0.5">{exp.company}</p>
                    </div>
                    <span class="gh-badge gh-badge--count text-[11px] font-mono sm:shrink-0 whitespace-nowrap self-start sm:self-auto">
                      {exp.period}
                    </span>
                  </div>
                  <p class="mt-3 text-[13px] gh-text-muted leading-normal">{exp.description}</p>
                </div>
              ))
            }
          </div>
        </section>

        <section>
          <h2 class="text-xs font-semibold text-[#1f2328] uppercase tracking-wider mb-3">
            Formation & Certifications
          </h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {
              educations.map((edu) => (
                <div class="gh-card p-3.5 flex flex-col justify-between">
                  <div>
                    <div class="flex items-start justify-between gap-2">
                      <h3 class="text-[13px] font-semibold gh-text leading-tight">{edu.title}</h3>
                      <span class="gh-badge gh-badge--date text-[10px] font-mono font-medium">
                        {edu.year}
                      </span>
                    </div>
                    <p class="text-xs gh-link font-medium mt-0.5">{edu.institution}</p>
                    <p class="mt-2 text-[12px] gh-text-muted leading-normal">{edu.details}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>

      <div class="space-y-4">
        <h2 class="text-xs font-semibold text-[#1f2328] uppercase tracking-wider">
          Compétences Techniques
        </h2>

        <SkillGroup title="IA & Automatisation" skills={skills.iaAuto} tone="success" />

        <SkillGroup title="Frontend" skills={skills.frontend} tone="info" />

        <SkillGroup title="Backend" skills={skills.backend} tone="info" />

        <SkillGroup title="Bases de données" skills={skills.database} tone="mono" />

        <SkillGroup title="DevOps & Outils" skills={skills.devops} tone="muted" />

        <div
          class="p-3 bg-[#fff8c5] border border-[#rgba(191,133,0,0.3)] rounded-md text-xs text-[#735c0f]"
        >
          <strong>Hobbies & Intérêts :</strong> Domotique (Home Assistant), Guitare, Photographie & Vidéo,
          Voyages (Australie, Irlande).
        </div>
      </div>
    </div>
  </div>
</Layout>
