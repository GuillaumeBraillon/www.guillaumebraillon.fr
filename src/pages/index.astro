---
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import HomeProjectCard from "../components/HomeProjectCard.astro";
import HomeSidebarItem from "../components/HomeSidebarItem.astro";
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
import { getPublishedCollection, sortByDateDesc } from "../lib/content";
import { getThumbnail } from "../lib/images";

const projects = sortByDateDesc(await getPublishedCollection("projects"));

const featuredProject = projects.find((p) => p.data.featured === true) || projects[0];

const otherProjects = projects.filter((p) => p.id !== featuredProject?.id).slice(0, 4);

const featuredProjectImage = featuredProject
  ? await getThumbnail("projects", featuredProject)
  : null;

const otherProjectsWithImages = await Promise.all(
  otherProjects.map(async (project) => ({
    project,
    img: await getThumbnail("projects", project),
  }))
);

const recentArticles = sortByDateDesc(await getPublishedCollection("articles")).slice(0, 3);
const recentVoyages = sortByDateDesc(await getPublishedCollection("voyages")).slice(0, 3);

const recentArticlesWithImages = await Promise.all(
  recentArticles.map(async (item) => ({
    item,
    img: await getThumbnail("articles", item),
  }))
);

const recentVoyagesWithImages = await Promise.all(
  recentVoyages.map(async (item) => ({
    item,
    img: await getThumbnail("voyages", item),
  }))
);
---

<Layout>
  <section class="pb-6 mb-6 border-b border-[#d0d7de]">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold text-[#1f2328] tracking-tight flex items-center gap-2">
          {site.name}
          <Badge variant="home">{site.home.badge}</Badge>
        </h1>
        <p class="mt-2 text-[14px] text-[#57606a] max-w-2xl leading-relaxed">
          {site.home.description}
        </p>
      </div>

      <div class="flex gap-2 shrink-0">
        <Button href="/cv" variant="primary"> Mon CV </Button>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <section>
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-[#1f2328]">Projet principal</span>
        </div>
        {
          featuredProject ? (
            <HomeProjectCard
              href={`/projects/${featuredProject.id}`}
              title={featuredProject.data.title}
              description={featuredProject.data.description}
              thumbnail={featuredProjectImage ?? undefined}
              thumbnailAlt={featuredProject.data.title}
            >
              <Badge slot="titleBadge" variant="public">
                Public
              </Badge>
              {featuredProject.data.tech && featuredProject.data.tech.length > 0 && (
                <span slot="meta" class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#3178c6]" />
                  {featuredProject.data.tech[0]}
                </span>
              )}
            </HomeProjectCard>
          ) : (
            <p class="text-xs text-[#636c76]">Aucun projet configuré.</p>
          )
        }
      </section>

      <section>
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-[#1f2328]">Autres projets</span>
          <a href="/projects" class="text-[11px] text-[#0969da] hover:underline">Tout voir</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {
            otherProjectsWithImages.length > 0 ? (
              otherProjectsWithImages.map(({ project: p, img }) => {
                return (
                  <HomeProjectCard
                    href={`/projects/${p.id}`}
                    title={p.data.title}
                    description={p.data.description}
                    thumbnail={img ?? undefined}
                    thumbnailAlt={p.data.title}
                    variant="compact"
                  >
                    {p.data.tech && p.data.tech.length > 0 && (
                      <span slot="meta" class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-[#f1e05a]" />
                        {p.data.tech[0]}
                      </span>
                    )}
                  </HomeProjectCard>
                );
              })
            ) : (
              <p class="text-xs text-[#636c76] col-span-2">Pas d'autres projets à afficher.</p>
            )
          }
        </div>
      </section>
    </div>

    <div class="space-y-6">
      {
        recentArticlesWithImages.length > 0 && (
          <section class="border border-[#d0d7de] rounded-md bg-white overflow-hidden">
            <div class="bg-[#f6f8fa] border-b border-[#d0d7de] px-4 py-2 flex items-center justify-between">
              <span class="text-xs font-semibold text-[#1f2328]">Articles récents</span>
              <a href="/articles" class="text-[11px] text-[#0969da] hover:underline">
                Tout voir
              </a>
            </div>
            <div class="divide-y divide-[#d0d7de]">
              {recentArticlesWithImages.map(({ item, img }) => (
                <HomeSidebarItem
                  href={`/articles/${item.id}`}
                  title={item.data.title}
                  thumbnail={img ?? undefined}
                />
              ))}
            </div>
          </section>
        )
      }
      {
        recentVoyagesWithImages.length > 0 && (
          <section class="border border-[#d0d7de] rounded-md bg-white overflow-hidden">
            <div class="bg-[#f6f8fa] border-b border-[#d0d7de] px-4 py-2 flex items-center justify-between">
              <span class="text-xs font-semibold text-[#1f2328]">Voyages</span>
              <a href="/voyages" class="text-[11px] text-[#0969da] hover:underline">
                Tout voir
              </a>
            </div>
            <div class="divide-y divide-[#d0d7de]">
              {recentVoyagesWithImages.map(({ item, img }) => (
                <HomeSidebarItem
                  href={`/voyages/${item.id}`}
                  title={item.data.title}
                  thumbnail={img ?? undefined}
                >
                  <span
                    slot="badge"
                    class="text-[11px] text-[#636c76] bg-[#eaeef2] px-1.5 py-0.5 rounded shrink-0"
                  >
                    {item.data.country}
                  </span>
                </HomeSidebarItem>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </div>
</Layout>
