---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
import { getPublishedCollection, sortByDateDesc } from "../lib/content";
import { getThumbnail } from "../lib/images";

const projects = sortByDateDesc(await getPublishedCollection("projects"));

const featuredProject = projects.find((p) => p.data.featured === true) || projects[0];

const otherProjects = projects.filter((p) => p.id !== featuredProject?.id).slice(0, 4);

const featuredProjectImage = featuredProject ? getThumbnail("projects", featuredProject) : null;

const sidebarSections = [
  {
    id: "articles" as const,
    label: "Articles récents",
    items: sortByDateDesc(await getPublishedCollection("articles")).slice(0, 3),
  },
  {
    id: "voyages" as const,
    label: "Voyages",
    items: sortByDateDesc(await getPublishedCollection("voyages")).slice(0, 3),
  },
];
---

<Layout>
  <section class="pb-6 mb-6 border-b border-[#d0d7de]">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold text-[#1f2328] tracking-tight flex items-center gap-2">
          {site.name}
          <span
            class="text-xs font-normal px-2 py-0.5 border border-[#d0d7de] text-[#636c76] rounded-full bg-[#f6f8fa]"
          >
            {site.home.badge}
          </span>
        </h1>
        <p class="mt-2 text-[14px] text-[#57606a] max-w-2xl leading-relaxed">
          {site.home.description}
        </p>
      </div>

      <div class="flex gap-2 shrink-0">
        <a
          href="/cv"
          class="px-3 py-1.5 text-xs font-semibold text-white bg-[#1f883d] border border-[rgba(27,31,36,0.15)] rounded-md shadow-sm hover:bg-[#1a7f37] active:bg-[#186c31] transition-colors"
        >
          Mon CV
        </a>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <section>
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-[#1f2328]">Projet principal</span>
        </div>
        {
          featuredProject ? (
            <div class="border border-[#d0d7de] rounded-md bg-white p-4 hover:border-[#0969da] transition-colors group flex gap-4">
              {featuredProjectImage && (
                <img
                  src={featuredProjectImage.src}
                  width={featuredProjectImage.width}
                  height={featuredProjectImage.height}
                  alt={featuredProject.data.title}
                  class="w-24 h-24 object-cover rounded shrink-0"
                  loading="lazy"
                />
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between">
                  <a
                    href={`/projects/${featuredProject.id}`}
                    class="text-[14px] font-semibold text-[#0969da] hover:underline flex items-center gap-1.5"
                  >
                    <svg
                      class="text-[#636c76]"
                      viewBox="0 0 16 16"
                      width="16"
                      height="16"
                      fill="currentColor"
                    >
                      <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 0 1 1-1h8z" />
                    </svg>
                    {featuredProject.data.title}
                  </a>
                  <span class="text-[12px] text-[#636c76] px-1.5 py-0.2 border border-[#d0d7de] rounded-full bg-[#f6f8fa]">
                    Public
                  </span>
                </div>
                <p class="mt-2 text-[12px] text-[#57606a] leading-normal line-clamp-2">
                  {featuredProject.data.description}
                </p>
                {featuredProject.data.tech && featuredProject.data.tech.length > 0 && (
                  <div class="mt-4 flex items-center gap-3 text-[12px] text-[#636c76]">
                    <span class="flex items-center gap-1.5">
                      <span class="w-2.5 h-2.5 rounded-full bg-[#3178c6]" />{" "}
                      {featuredProject.data.tech[0]}
                    </span>
                  </div>
                )}
              </div>
            </div>
          ) : (
            <p class="text-xs text-[#636c76]">Aucun projet configuré.</p>
          )
        }
      </section>

      <section>
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-[#1f2328]">Autres projets</span>
          <a href="/projects" class="text-[11px] text-[#0969da] hover:underline">Tout voir</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {
            otherProjects.length > 0 ? (
              otherProjects.map((p) => {
                const img = getThumbnail("projects", p);
                return (
                  <div class="border border-[#d0d7de] rounded-md bg-white p-3.5 flex gap-3 hover:border-[#0969da] transition-colors">
                    {img && (
                      <img
                        src={img.src}
                        width={img.width}
                        height={img.height}
                        alt={p.data.title}
                        class="w-16 h-16 object-cover rounded shrink-0"
                        loading="lazy"
                      />
                    )}
                    <div class="flex flex-col justify-between min-w-0 flex-1">
                      <div>
                        <a
                          href={`/projects/${p.id}`}
                          class="text-[14px] font-semibold text-[#0969da] hover:underline flex items-center gap-1.5"
                        >
                          <svg
                            class="text-[#636c76]"
                            viewBox="0 0 16 16"
                            width="14"
                            height="14"
                            fill="currentColor"
                          >
                            <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 0 1 1-1h8z" />
                          </svg>
                          {p.data.title}
                        </a>
                        <p class="mt-1 text-[12px] text-[#57606a] line-clamp-2 leading-normal">
                          {p.data.description}
                        </p>
                      </div>
                      {p.data.tech && p.data.tech.length > 0 && (
                        <div class="mt-3 text-[12px] text-[#636c76] flex items-center gap-1.5">
                          <span class="w-2.5 h-2.5 rounded-full bg-[#f1e05a]" /> {p.data.tech[0]}
                        </div>
                      )}
                    </div>
                  </div>
                );
              })
            ) : (
              <p class="text-xs text-[#636c76] col-span-2">Pas d'autres projets à afficher.</p>
            )
          }
        </div>
      </section>
    </div>

    <div class="space-y-6">
      {
        sidebarSections.map(
          (section) =>
            section.items.length > 0 && (
              <section class="border border-[#d0d7de] rounded-md bg-white overflow-hidden">
                <div class="bg-[#f6f8fa] border-b border-[#d0d7de] px-4 py-2 flex items-center justify-between">
                  <span class="text-xs font-semibold text-[#1f2328]">{section.label}</span>
                  <a href={`/${section.id}`} class="text-[11px] text-[#0969da] hover:underline">
                    Tout voir
                  </a>
                </div>
                <div class="divide-y divide-[#d0d7de]">
                  {section.id === "articles"
                    ? section.items.map((item) => {
                        const img = getThumbnail("articles", item);
                        return (
                          <a
                            href={`/articles/${item.id}`}
                            class="flex items-center gap-3 px-4 py-2.5 hover:bg-[#f6f8fa] group transition-colors"
                          >
                            {img && (
                              <img
                                src={img.src}
                                width={img.width}
                                height={img.height}
                                alt={item.data.title}
                                class="w-12 h-12 object-cover rounded shrink-0"
                                loading="lazy"
                              />
                            )}
                            <span class="text-[13px] font-medium text-[#1f2328] group-hover:text-[#0969da] truncate">
                              {item.data.title}
                            </span>
                          </a>
                        );
                      })
                    : section.items.map((item) => {
                        const img = getThumbnail("voyages", item);
                        return (
                          <a
                            href={`/voyages/${item.id}`}
                            class="flex items-center gap-3 px-4 py-2.5 hover:bg-[#f6f8fa] group transition-colors"
                          >
                            {img && (
                              <img
                                src={img.src}
                                width={img.width}
                                height={img.height}
                                alt={item.data.title}
                                class="w-12 h-12 object-cover rounded shrink-0"
                                loading="lazy"
                              />
                            )}
                            <div class="flex items-center justify-between gap-2 min-w-0 flex-1">
                              <span class="text-[13px] font-medium text-[#1f2328] group-hover:text-[#0969da] truncate">
                                {item.data.title}
                              </span>
                              <span class="text-[11px] text-[#636c76] bg-[#eaeef2] px-1.5 py-0.5 rounded shrink-0">
                                {item.data.country}
                              </span>
                            </div>
                          </a>
                        );
                      })}
                </div>
              </section>
            )
        )
      }
    </div>
  </div>
</Layout>
