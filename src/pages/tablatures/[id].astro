---
import Badge from "../../components/Badge.astro";
import ContentHeader from "../../components/ContentHeader.astro";
import MarkdownImages from "../../components/MarkdownImages.astro";
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { formatDateFr, getPublishedCollection } from "../../lib/content";

export async function getStaticPaths() {
  const tablatures = await getPublishedCollection("tablatures");
  return tablatures.map((tablature) => ({
    params: { id: tablature.id },
    props: { tablature },
  }));
}

const { tablature } = Astro.props;
const { data } = tablature;
const { Content } = await render(tablature);
const formattedDate = formatDateFr(data.date);
---

<Layout title={data.title}>
  <article class="space-y-6">
    <ContentHeader href="/tablatures" label="Tablatures" current={tablature.id} title={data.title}>
      <span slot="meta" class="font-medium text-[#1f2328]">{formattedDate}</span>
      {
        data.tags &&
          data.tags.length > 0 &&
          data.tags.map((tag: string) => (
            <Badge slot="meta" variant="tag">
              {tag}
            </Badge>
          ))
      }
    </ContentHeader>

    <div class="prose prose-sm max-w-none text-[#1f2328] space-y-4 markdown-body">
      <Content />
    </div>
    <MarkdownImages />
  </article>
</Layout>
