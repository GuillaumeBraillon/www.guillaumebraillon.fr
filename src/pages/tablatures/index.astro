---
import Badge from "../../components/Badge.astro";
import CollectionListItem from "../../components/CollectionListItem.astro";
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import { formatDateFr, getPublishedCollection, sortByDateDesc } from "../../lib/content";

const tablatures = sortByDateDesc(await getPublishedCollection("tablatures"));
---

<Layout title="Tablatures">
  <PageHeader title="Tablatures" count={tablatures.length} />

  <div class="divide-y divide-[#d0d7de]">
    {
      tablatures.map((tablature) => (
        <CollectionListItem
          href={`/tablatures/${tablature.id}`}
          title={tablature.data.title}
          description={tablature.data.description}
        >
          <Badge slot="meta" variant="date">
            {formatDateFr(tablature.data.date)}
          </Badge>
          {tablature.data.tags &&
            tablature.data.tags.map((tag) => (
              <Badge slot="meta" variant="tag">
                {tag}
              </Badge>
            ))}
        </CollectionListItem>
      ))
    }
  </div>
</Layout>
