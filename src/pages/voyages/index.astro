---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const voyages = await getCollection("voyages");

// Tri décroissant sur la date
const sortedVoyages = voyages.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Voyages explorés">
  <div class="pb-4 mb-2 border-b border-[#d0d7de]">
    <h1 class="text-xl font-semibold text-[#1f2328] flex items-center gap-2">
      Voyages explorés
      <span class="text-xs font-normal px-2 py-0.5 bg-[#eaeef2] text-[#636c76] rounded-full">
        {voyages.length}
      </span>
    </h1>
  </div>

  <div class="divide-y divide-[#d0d7de]">
    {
      sortedVoyages.map((voyage) => (
        <div class="py-4 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
          <div class="space-y-1 max-w-3xl">
            <div class="flex items-center gap-2">
              <a
                href={`/voyages/${voyage.id}`}
                class="text-lg font-semibold text-[#0969da] hover:underline flex items-center gap-2"
              >
                <svg
                  class="text-[#636c76]"
                  viewBox="0 0 16 16"
                  width="16"
                  height="16"
                  fill="currentColor"
                >
                  <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM4.5 5a.5.5 0 0 0 0 1h7a.5.5 0 0 0 0-1h-7Zm0 2.5a.5.5 0 0 0 0 1h7a.5.5 0 0 0 0-1h-7Zm0 2.5a.5.5 0 0 0 0 1h4a.5.5 0 0 0 0-1h-4Z" />
                </svg>
                {voyage.data.title}
              </a>
              <span class="text-[12px] font-medium text-[#636c76] px-2 py-0.2 border border-[#d0d7de] rounded-full bg-[#f6f8fa]">
                {voyage.data.country}
              </span>
            </div>
            {voyage.data.description && (
              <p class="text-[14px] text-[#57606a] leading-normal">{voyage.data.description}</p>
            )}
          </div>

          <div class="flex items-center gap-2 text-xs text-[#636c76] shrink-0 sm:pt-1 font-medium">
            <span class="bg-[#eaeef2] px-2 py-0.5 rounded">{voyage.data.period}</span>
          </div>
        </div>
      ))
    }
  </div>
</Layout>
