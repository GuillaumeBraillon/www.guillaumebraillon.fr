---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const voyages = await getCollection("voyages");

// Tri robuste : gère les dates complètes et les années seules
const sortedVoyages = voyages.sort((a, b) => {
  const dateA = a.data.date instanceof Date ? a.data.date : new Date(a.data.date);
  const dateB = b.data.date instanceof Date ? b.data.date : new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});
---

<Layout title="Voyages">
  <div class="pb-4 mb-2 border-b border-[#d0d7de]">
    <h1 class="text-xl font-semibold text-[#1f2328] flex items-center gap-2">
      Voyages explorés
      <span class="text-xs font-normal px-2 py-0.5 bg-[#eaeef2] text-[#636c76] rounded-full">
        {voyages.length}
      </span>
    </h1>
  </div>

  <div class="divide-y divide-[#d0d7de]">
    {
      sortedVoyages.map((voyage) => (
        <div class="py-4 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
          <div class="space-y-1 max-w-3xl">
            <div class="flex items-center gap-2">
              <a
                href={`/voyages/${voyage.id}`}
                class="text-lg font-semibold text-[#0969da] hover:underline flex items-center gap-2"
              >
                <svg
                  class="text-[#636c76]"
                  viewBox="0 0 16 16"
                  width="16"
                  height="16"
                  fill="currentColor"
                >
                  <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 0 1 1-1h8z" />
                </svg>
                {voyage.data.title}
              </a>
              <span class="text-[12px] font-medium text-[#636c76] px-2 py-0.2 border border-[#d0d7de] rounded-full bg-[#f6f8fa]">
                {voyage.data.country}
              </span>
            </div>

            {voyage.data.description && (
              <p class="text-[14px] text-[#57606a] leading-normal">{voyage.data.description}</p>
            )}

            <div class="pt-2 flex flex-wrap gap-1.5">
              <span class="text-[11px] text-[#0969da] bg-[#ddf4ff] px-2 py-0.5 rounded-full font-medium">
                {voyage.data.period}
              </span>
              {voyage.data.duration && (
                <span class="text-[11px] text-[#1a7f37] bg-[#dafbe1] px-2 py-0.5 rounded-full font-medium">
                  {voyage.data.duration}
                </span>
              )}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</Layout>
