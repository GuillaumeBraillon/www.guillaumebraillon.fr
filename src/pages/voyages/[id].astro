---
import Badge from "../../components/Badge.astro";
import ContentHeader from "../../components/ContentHeader.astro";
import MarkdownImages from "../../components/MarkdownImages.astro";
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import TravelMap from "../../components/TravelMap.astro";
import { itineraries } from "../../data/itineraries";
import { getPublishedCollection } from "../../lib/content";

export async function getStaticPaths() {
  const voyages = await getPublishedCollection("voyages");
  return voyages.map((voyage) => ({
    params: { id: voyage.id },
    props: { voyage },
  }));
}

const { voyage } = Astro.props;
const { data } = voyage;
const { Content } = await render(voyage);
---

<Layout title={data.title}>
  <article class="space-y-6">
    <ContentHeader href="/voyages" label="Voyages" current={voyage.id} title={data.title}>
      <span slot="meta" class="text-sm text-[#57606a]">{data.country} · {data.period}</span>
      {
        data.tags &&
          data.tags.length > 0 &&
          data.tags.map((tag: string) => (
            <Badge slot="meta" variant="tag">
              {tag}
            </Badge>
          ))
      }
    </ContentHeader>
    {
      data.itinerary && itineraries[data.itinerary] && (
        <div class="my-6">
          <h2 class="text-lg font-semibold text-[#1f2328] mb-3">Tracé de l'itinéraire</h2>
          <TravelMap locations={itineraries[data.itinerary]} />
        </div>
      )
    }
    <div class="prose prose-sm max-w-none markdown-body">
      <Content />
    </div>
    <MarkdownImages />
  </article>
</Layout>
