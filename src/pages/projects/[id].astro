---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { marked } from "marked";
import { getPublishedCollection } from "../../lib/content";

export async function getStaticPaths() {
  const projects = await getPublishedCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project: project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Normalisation de l'URL pour requêter le fichier brut (RAW) sur la branche main
const rawReadmeUrl = `${project.data.githubUrl.replace("github.com", "raw.githubusercontent.com")}/main/README.md`;

let readmeHtml = "";
try {
  const response = await fetch(rawReadmeUrl);
  if (response.ok) {
    const markdownText = await response.text();

    // URL de base brute pour ton dépôt
    const baseRepoUrl = project.data.githubUrl.replace("github.com", "raw.githubusercontent.com");

    // Remplacement propre et direct de toutes les variantes de chemins relatifs menant à public/
    const correctedMarkdown = markdownText
      .replaceAll("(public/", `(${baseRepoUrl}/main/public/`)
      .replaceAll('src="public/', `src="${baseRepoUrl}/main/public/`)
      .replaceAll("src='public/", `src='${baseRepoUrl}/main/public/`);

    // Conversion du Markdown corrigé en HTML
    readmeHtml = await marked.parse(correctedMarkdown);
  }
} catch {
  // Fallback silencieux sur le contenu Astro
}
---

<Layout title={project.data.title}>
  <article class="space-y-6">
    <header
      class="pb-5 border-b border-[#d0d7de] flex flex-col sm:flex-row sm:items-center justify-between gap-4"
    >
      <div>
        <div class="flex flex-wrap items-center gap-2 text-sm text-[#636c76] mb-1.5">
          <a href="/projects" class="text-[#0969da] hover:underline">Projets</a>
          <span>/</span>
          <span class="font-semibold text-[#1f2328]">{project.id}</span>
        </div>

        <h1 class="text-2xl font-semibold text-[#1f2328] tracking-tight">
          {project.data.title}
        </h1>

        <p class="mt-1.5 text-[14px] text-[#57606a] leading-relaxed max-w-2xl">
          {project.data.description}
        </p>
      </div>

      <div class="shrink-0 not-prose">
        <a
          href={project.data.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-[#24292f] bg-[#f6f8fa] border border-[#d0d7de] rounded-md shadow-sm hover:bg-[#f3f4f6] hover:border-[#c8d1d9] transition-colors"
        >
          <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
            <path
              d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82A7.49 7.49 0 0 0 8 3c-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.16.73.72.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"
            ></path>
          </svg>
          Repository Code
        </a>
      </div>
    </header>

    {
      readmeHtml ? (
        <div
          class="prose prose-sm max-w-none text-[#1f2328] space-y-4 markdown-body"
          set:html={readmeHtml}
        />
      ) : (
        <div class="prose prose-sm max-w-none text-[#1f2328] space-y-4 markdown-body">
          <Content />
        </div>
      )
    }
  </article>
</Layout>
