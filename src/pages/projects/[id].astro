---
import Breadcrumb from "../../components/Breadcrumb.astro";
import Button from "../../components/Button.astro";
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getPublishedCollection } from "../../lib/content";

export async function getStaticPaths() {
  const projects = await getPublishedCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project: project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const rawReadmeUrl = `${project.data.githubUrl.replace("github.com", "raw.githubusercontent.com")}/main/README.md`;
const rawRepoBaseUrl = project.data.githubUrl.replace("github.com", "raw.githubusercontent.com");
---

<Layout title={project.data.title}>
  <article class="space-y-6">
    <header
      class="pb-5 border-b border-[#d0d7de] flex flex-col sm:flex-row sm:items-center justify-between gap-4"
    >
      <div>
        <Breadcrumb collectionHref="/projects" collectionLabel="Projets" entryLabel={project.id} />

        <h1 class="text-2xl font-semibold text-[#1f2328] tracking-tight">
          {project.data.title}
        </h1>

        <p class="mt-1.5 text-[14px] text-[#57606a] leading-relaxed max-w-2xl">
          {project.data.description}
        </p>

        <div class="mt-3 flex items-center gap-2 text-[12px] text-[#57606a]">
          <span
            class="inline-flex items-center rounded-full border border-[#d0d7de] bg-[#f6f8fa] px-2 py-0.5 font-medium text-[#1f2328]"
          >
            Source du contenu:
            <span id="project-readme-source" class="ml-1 text-[#0969da]">Local</span>
          </span>
        </div>
      </div>

      <div class="shrink-0 not-prose">
        <Button href={project.data.githubUrl} external> Repository Code </Button>
      </div>
    </header>

    <div
      id="project-readme"
      class="prose prose-sm max-w-none text-[#1f2328] space-y-4 markdown-body"
      data-readme-url={rawReadmeUrl}
      data-repo-base-url={rawRepoBaseUrl}
      aria-busy="false"
    >
      <Content />
    </div>
  </article>

  <script is:inline type="module">
    import { marked } from "https://esm.sh/marked@18";

    const root = document.querySelector("#project-readme");
    const sourceBadge = document.querySelector("#project-readme-source");

    if (root instanceof HTMLElement) {
      const readmeUrl = root.dataset.readmeUrl;
      const repoBaseUrl = root.dataset.repoBaseUrl;

      if (readmeUrl && repoBaseUrl) {
        root.setAttribute("aria-busy", "true");
        if (sourceBadge instanceof HTMLElement) {
          sourceBadge.textContent = "Chargement GitHub...";
        }

        fetch(readmeUrl, { cache: "no-store" })
          .then((response) => {
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`);
            }

            return response.text();
          })
          .then((markdownText) => {
            const correctedMarkdown = markdownText
              .replaceAll("(public/", `(${repoBaseUrl}/main/public/`)
              .replaceAll('src="public/', `src="${repoBaseUrl}/main/public/`)
              .replaceAll("src='public/", `src='${repoBaseUrl}/main/public/`);

            return marked.parse(correctedMarkdown);
          })
          .then((html) => {
            root.innerHTML = html;
            if (sourceBadge instanceof HTMLElement) {
              sourceBadge.textContent = "GitHub";
            }
          })
          .catch(() => {
            // On garde le rendu Astro local si GitHub n'est pas disponible.
            if (sourceBadge instanceof HTMLElement) {
              sourceBadge.textContent = "Local";
            }
          })
          .finally(() => {
            root.setAttribute("aria-busy", "false");
          });
      }
    }
  </script>
</Layout>
