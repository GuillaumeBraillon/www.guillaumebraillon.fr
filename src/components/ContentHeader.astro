---
import Breadcrumb from "./Breadcrumb.astro";

interface Props {
  href: string;
  label: string;
  current: string;
  title: string;
  description?: string;
}

const { href, label, title, description } = Astro.props as Props;
---

<header
  class="pb-5 gh-divider-bottom flex flex-col sm:flex-row sm:items-center justify-between gap-4"
>
  <div>
    <Breadcrumb collectionHref={href} collectionLabel={label} />
    <h1 class="text-2xl font-semibold gh-text tracking-tight">{title}</h1>
    {
      description && (
        <p class="mt-1.5 text-[14px] gh-text-muted leading-relaxed max-w-2xl">{description}</p>
      )
    }
    <div class="mt-2 flex flex-wrap items-center gap-3 text-sm gh-text-muted">
      <slot name="meta" />
    </div>
  </div>

  <div class="shrink-0 not-prose">
    <slot name="actions" />
  </div>
</header>
