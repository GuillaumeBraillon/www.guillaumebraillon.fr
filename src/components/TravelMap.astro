---
// src/components/TravelMap.astro

interface Props {
  locations: Array<{
    name: string;
    date?: string;
    location?: string;
    coords: [number, number];
    details?: string;
  }>;
}

const { locations } = Astro.props;
---

<div id="map" data-locations={JSON.stringify(locations)}></div>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";

  // Correction de la résolution des assets d'icônes par défaut avec Vite
  import markerIcon from "leaflet/dist/images/marker-icon.png";
  import markerIconRetina from "leaflet/dist/images/marker-icon-2x.png";
  import markerShadow from "leaflet/dist/images/marker-shadow.png";

  const DefaultIcon = L.icon({
    iconUrl: markerIcon.src,
    iconRetinaUrl: markerIconRetina.src,
    shadowUrl: markerShadow.src,
    iconSize: [25, 41],
    iconAnchor: [12, 41],
    popupAnchor: [1, -34],
    shadowSize: [41, 41],
  });
  L.Marker.prototype.options.icon = DefaultIcon;

  // Initialisation de la carte au chargement côté client
  const mapContainer = document.getElementById("map");

  if (mapContainer) {
    const locations = JSON.parse(mapContainer.dataset.locations || "[]");

    // On centre par défaut sur l'Australie
    const map = L.map("map").setView([-25.2744, 133.7751], 4);

    // Ajout des tuiles OpenStreetMap
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "© OpenStreetMap contributors",
    }).addTo(map);

    const pathCoordinates: L.LatLngExpression[] = [];

    // Ajout des points et des popups
    locations.forEach(
      (loc: {
        name: string;
        date?: string;
        location?: string;
        coords: [number, number];
        details?: string;
        anchor?: string;
      }) => {
        L.marker(loc.coords).addTo(map).bindPopup(`
            <div style="min-width:220px;">
              <strong>${loc.name}</strong>
              ${loc.date ? `<br><small><strong>Date :</strong> ${loc.date}</small>` : ""}
              ${loc.location ? `<br><small><strong>Lieu :</strong> ${loc.location}</small>` : ""}
              ${loc.details ? `<hr style="margin:8px 0;"><div style="font-size:12px;color:#57606a;">${loc.details}</div>` : ""}
              ${loc.anchor ? `<a href="road-trip-en-australie-2005-2006#${loc.anchor}">En savoir plus</a>` : ""}            </div>
          `);

        pathCoordinates.push(loc.coords);
      }
    );

    // Tracé de la ligne reliant les étapes du road-trip
    if (pathCoordinates.length > 1) {
      L.polyline(pathCoordinates, { color: "#0969da", weight: 3, dashArray: "6, 6" }).addTo(map);

      // Ajustement automatique du zoom pour englober tous les marqueurs présents
      const bounds = L.latLngBounds(pathCoordinates);
      map.fitBounds(bounds, { padding: [50, 50] });
    }
  }
</script>

<style>
  #map {
    height: 450px;
    width: 100%;
    border-radius: 6px;
    border: 1px solid #d0d7de;
    margin-bottom: 1.5rem;
  }
</style>
